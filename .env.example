# resq.sh — environment configuration
#
# Copy this file to `.env` (kept out of git by the repo-root **/.env rule)
# and fill in the values you need. Variables defined here are sourced by
# resq.sh at startup, so they are available to restic for the entire run.

# ── Backblaze B2 credentials ──
# Required when repos.conf contains a `b2:` repo entry.
# Use an application key restricted to a single bucket — not the master key.
# B2_ACCOUNT_ID is the keyID (NOT the master account ID).
#B2_ACCOUNT_ID=
#B2_ACCOUNT_KEY=

# ── S3 / S3-compatible credentials ──
# Required when repos.conf contains an `s3:` repo entry.
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#AWS_DEFAULT_REGION=

# ── Bind mount auto-discovery exclusions ──
# Pipe-separated regex applied to each bind-mount source path. A match skips
# the mount. Defaults shown below — uncomment + adjust to override.
#BIND_EXCLUDE="/etc/timezone|/etc/localtime|/etc/hosts|/etc/resolv.conf|/etc/hostname|/var/run/docker.sock|/dev/|/proc/|/sys/"
